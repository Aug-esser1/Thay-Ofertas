  return (
    <div className="max-w-4xl mx-auto py-12 px-6 lg:py-24">
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
      >
        <div className="text-[11px] uppercase tracking-widest font-bold text-brand-primary mb-4 italic">Conteúdo</div>
        <h1 className="font-display text-4xl lg:text-6xl italic leading-tight mb-12">
          Como escolher os melhores produtos <br className="hidden lg:block" />
